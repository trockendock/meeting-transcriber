# ==========================================
# Meeting Protokollant -- Konfiguration
# ==========================================
# Kopiere diese Datei nach .env und passe die Werte an:
#   cp .env.example .env

# Pfad zum Projektordner (wird von install.sh automatisch gesetzt)
# Manuell: absoluter Pfad zum WhisperSystem-Ordner, z.B.:
#   /Volumes/MeineSSD/WhisperSystem
#   ~/WhisperSystem
SSD_PATH=

# Whisper-Modell fuer die Transkription
# "auto" = Schweizerdeutsch-Modell (Flurin17) mit Auto-Konvertierung nach MLX
#          Falls Konvertierung nicht moeglich: Fallback auf deutsches MLX-Modell
# Oder manuell setzen, z.B.:
#   mlx-community/whisper-large-v3-turbo-german-f16        (Deutsch, MLX-nativ)
#   /pfad/zu/WhisperSystem/models/ch-whisper-mlx           (lokal konvertiert)
WHISPER_MODEL=auto

# Ollama-Modell fuer die Zusammenfassung
OLLAMA_MODEL=mistral-nemo

# Ollama Server-URL (Standard: lokal)
OLLAMA_URL=http://localhost:11434

# Sprechererkennung aktivieren? (true/false)
# Benoetigt HF_TOKEN und pyannote.audio
ENABLE_DIARIZATION=false

# Hugging Face Token (nur noetig wenn ENABLE_DIARIZATION=true)
# Erstellen unter: https://huggingface.co/settings/tokens
# Danach Nutzungsbedingungen akzeptieren:
#   https://huggingface.co/pyannote/speaker-diarization-3.1
#   https://huggingface.co/pyannote/segmentation-3.0
HF_TOKEN=

# Korrekturliste fuer Transkriptionsfehler (Firmennamen, Fachbegriffe)
# Whisper kennt keine Firmennamen -- hier korrekte Schreibweise eintragen
# Format: FalscheSchreibweise:KorrekteSchreibweise (kommagetrennt)
# Beispiel:
#   TRANSCRIPT_CORRECTIONS=Mantelux:Montalux,Strahlhorn:Strahlhorn AG
TRANSCRIPT_CORRECTIONS=
